# ============================================================
# CtrlShift+ — .gitignore
# ============================================================

# --- Secrets & credentials (NEVER commit these) -------------
.env
.env.*
!.env.example
*.pem
*.key
*.p12
*.pfx
secrets/
credentials/
**/tokens.json
**/oauth_tokens.*
slack_token*
jira_token*
graph_token*
microsoft_credentials*

# --- Node.js ------------------------------------------------
node_modules/
npm-debug.log*
yarn-debug.log*
yarn-error.log*
pnpm-debug.log*
.pnpm-store/
.npm/
.yarn/
dist/
build/
.next/
.nuxt/
out/
coverage/
*.tsbuildinfo

# --- Python -------------------------------------------------
__pycache__/
*.py[cod]
*.pyo
*.pyd
.Python
venv/
.venv/
env/
ENV/
env.bak/
pip-log.txt
pip-delete-this-directory.txt
*.egg-info/
dist/
build/
.eggs/
.pytest_cache/
.mypy_cache/
.ruff_cache/
htmlcov/
.coverage
.coverage.*
coverage.xml

# --- Database & local state ---------------------------------
*.sqlite
*.sqlite3
*.db
*.db-shm
*.db-wal
data/
state/
local_state/

# --- IDE & editor -------------------------------------------
.vscode/
!.vscode/extensions.json
!.vscode/settings.json.example
.idea/
*.suo
*.ntvs*
*.njsproj
*.sln
*.sw?
.DS_Store
Thumbs.db
desktop.ini

# --- Logs ---------------------------------------------------
logs/
*.log
npm-debug.log
yarn-debug.log

# --- Test artifacts -----------------------------------------
test-results/
playwright-report/
*.snap

# --- Misc ---------------------------------------------------
.cache/
tmp/
temp/
*.tmp
*.bak
*.orig
