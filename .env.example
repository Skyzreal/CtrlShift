# ── Slack ──────────────────────────────────────────────────────────────
# Bot token from: Slack App > OAuth & Permissions > Bot User OAuth Token
SLACK_BOT_TOKEN=xoxb-

# User token from: Slack App > OAuth & Permissions > User OAuth Token
# Required for setting DND and profile status on behalf of the user
SLACK_USER_TOKEN=xoxp-

# Signing secret from: Slack App > Basic Information > App Credentials
SLACK_SIGNING_SECRET=

# App-level token from: Slack App > Basic Information > App-Level Tokens
# Required for Socket Mode. Create one with connections:write scope.
# If omitted, the app runs in HTTP mode on PORT instead.
SLACK_APP_TOKEN=xapp-

# Your own Slack user ID (the single user this bot serves).
# Find it in Slack: click your profile > three dots > Copy member ID
SLACK_USER_ID=U

# ── Claude / Anthropic ─────────────────────────────────────────────────
ANTHROPIC_API_KEY=sk-ant-

# ── Jira (optional — omit to use mock data from dev/mock-jira.json) ────
JIRA_BASE_URL=https://yourorg.atlassian.net
JIRA_USER_EMAIL=you@example.com
# Generate at: id.atlassian.com > Security > API tokens
JIRA_API_TOKEN=

# ── Microsoft Graph / Outlook (optional) ───────────────────────────────
# Register an app at: portal.azure.com > App registrations
# Grant delegated permission: Calendars.ReadWrite
AZURE_CLIENT_ID=
AZURE_TENANT_ID=
# Populated automatically by running: npm run auth:graph
GRAPH_ACCESS_TOKEN=
GRAPH_REFRESH_TOKEN=

# ── Storage ────────────────────────────────────────────────────────────
DATABASE_PATH=./data/ctrlshift.db

# ── Server ─────────────────────────────────────────────────────────────
PORT=3000
NODE_ENV=development
